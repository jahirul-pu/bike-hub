generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Vehicle {
  id                  String      @id @default(cuid())
  slug                String?     @unique
  brand               String?
  model               String?
  name                String?
  category            String?
  powertrain          String      @default("ICE")
  priceBdt            Float?
  displacementCc      Float?
  motorPowerKw        Float?
  topSpeedKph         Float?
  mileageKmpl         Float?
  rangeKm             Float?
  chargingTime0100    String?
  batteryCycleLife    String?
  ipRating            String?
  fuelTankLiters      Float?
  gearbox             String?
  torqueNm            Float?
  weightKg            Float?
  seatHeightMm        Float?
  wheelbaseMm         Float?
  groundClearanceMm   Float?
  frontTyre           String?
  rearTyre            String?
  summary             String?

  vin                 String?
  chassis             String?
  certificationStatus String      @default("PENDING_APPROVAL")
  askingPrice         Float?
  price               Float?
  createdAt           DateTime    @default(now())
  
  inspection          Inspection?
}

model Inspection {
  id           String   @id @default(cuid())
  status       String   @default("Pending")
  technicianId String?
  vehicleId    String   @unique
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Part {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  stock       Int      @default(0)
  retailPrice Float?
  price       Float?
  createdAt   DateTime @default(now())
}
